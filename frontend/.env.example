# API base must include the /api prefix (see frontend/lib/api.ts).

# Local desktop:
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api

# Same Wi-Fi phone testing (replace with your PC LAN IP):
# NEXT_PUBLIC_API_BASE_URL=http://192.168.x.x:8000/api

# Cloudflare backend tunnel (replace with your HTTPS tunnel host; no path except /api):
# NEXT_PUBLIC_API_BASE_URL=https://your-backend-host.example.com/api

# Quick Tunnel example shape (URL changes every run — do not commit real URLs):
# NEXT_PUBLIC_API_BASE_URL=https://xxxx.trycloudflare.com/api
